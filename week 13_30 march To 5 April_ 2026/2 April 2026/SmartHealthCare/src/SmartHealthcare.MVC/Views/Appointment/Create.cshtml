@model SmartHealthcare.Models.DTOs.CreateAppointmentDTO

@{
    ViewData["Title"] = "Book Appointment";
}

<div class="content-area">

    <!-- 🔙 Back Button -->
    <div class="mb-3">
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
            ← Back
        </a>
    </div>

    <!-- 🔥 CARD -->
    <div class="card p-4">

        <!-- TITLE -->
        <div class="mb-4">
            <h2 class="fw-bold">Book Appointment</h2>
            <p class="text-muted">Schedule your visit with a doctor</p>
        </div>

        <!-- FORM -->
        <form asp-action="Create" method="post" novalidate>

            <!-- VALIDATION -->
            <div asp-validation-summary="All" class="alert alert-danger"></div>

            <!-- 🔥 DOCTOR DROPDOWN (FIXED) -->
            <div class="mb-4">
                <label asp-for="DoctorId" class="form-label fw-semibold">
                    Select Doctor *
                </label>

                <select asp-for="DoctorId"
                        asp-items="ViewBag.Doctors"
                        class="form-select">
                    <option value="">-- Choose a doctor --</option>
                </select>

                <span asp-validation-for="DoctorId" class="text-danger small"></span>
            </div>

            <!-- 📅 DATE -->
            <div class="mb-4">
                <label asp-for="AppointmentDate" class="form-label fw-semibold">
                    Appointment Date & Time *
                </label>

                <input asp-for="AppointmentDate"
                       type="datetime-local"
                       class="form-control" />

                <span asp-validation-for="AppointmentDate" class="text-danger small"></span>
            </div>

            <!-- 📝 NOTES -->
            <div class="mb-4">
                <label asp-for="Notes" class="form-label fw-semibold">
                    Notes (Optional)
                </label>

                <textarea asp-for="Notes"
                          class="form-control"
                          rows="4"
                          placeholder="Describe your symptoms..."></textarea>

                <span asp-validation-for="Notes" class="text-danger small"></span>
            </div>

            <!-- 🔘 BUTTONS -->
            <div class="d-flex justify-content-between">
                <button type="submit" class="btn btn-success">
                    Book Appointment
                </button>

                <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                    Cancel
                </a>
            </div>

        </form>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}