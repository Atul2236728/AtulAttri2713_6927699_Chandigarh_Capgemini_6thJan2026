<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Smart Healthcare</title>

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Bootstrap -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

    <!-- Custom -->
    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body>

<div class="app-container">

    <!-- 🔥 SIDEBAR -->
    <aside class="sidebar">
        <div class="sidebar-header">
            <h4><i class="fa-solid fa-hospital"></i> Healthcare</h4>
        </div>

        <ul class="sidebar-menu">
            <li><a asp-controller="Home" asp-action="Index"><i class="fa fa-home"></i> Home</a></li>
            <li><a asp-controller="Doctor" asp-action="Index"><i class="fa fa-user-md"></i> Doctors</a></li>

            @if (Context.Session.GetString("Token") != null)
            {
                <li><a asp-controller="Dashboard" asp-action="Index"><i class="fa fa-chart-line"></i> Dashboard</a></li>
                <li><a asp-controller="Appointment" asp-action="Index"><i class="fa fa-calendar"></i> Appointments</a></li>
                <li><a asp-controller="Patient" asp-action="Profile"><i class="fa fa-user"></i> Profile</a></li>
                <li><a asp-controller="Admin" asp-action="Reports"><i class="fa fa-cog"></i> Admin</a></li>
            }
        </ul>
    </aside>

    <!-- 🔥 MAIN AREA -->
    <div class="main-content">

        <!-- 🔝 TOPBAR -->
        <header class="topbar">
            <div class="d-flex justify-content-end align-items-center gap-3">

                @if (Context.Session.GetString("Token") != null)
                {
                    <span class="user-name">@Context.Session.GetString("FullName")</span>
                    <a class="btn btn-danger btn-sm" asp-controller="Account" asp-action="Logout">
                        Logout
                    </a>
                }
                else
                {
                    <a class="btn btn-outline-primary btn-sm" asp-controller="Account" asp-action="Login">Login</a>
                    <a class="btn btn-primary btn-sm" asp-controller="Account" asp-action="Register">Register</a>
                }

            </div>
        </header>

        <!-- 📦 PAGE CONTENT -->
        <main class="content-area">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">@TempData["Error"]</div>
            }

            @RenderBody()
        </main>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js"></script>

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>