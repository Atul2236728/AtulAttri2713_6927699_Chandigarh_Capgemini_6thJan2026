@using System.Text.Json
@{
    ViewData["Title"] = "Book Appointment";
    var fieldCategories = ViewBag.FieldCategories as Dictionary<string, string> ?? new Dictionary<string, string>();
    var selectedField = ViewBag.SelectedField as string;
    var doctors = ViewBag.Doctors as List<Dictionary<string, object>> ?? new List<Dictionary<string, object>>();
}

<div class="row">
    <div class="col-12 mb-4">
        <div class="card">
            <div class="card-body">
                <h4 class="mb-3"><i class="bi bi-calendar-plus text-primary me-2"></i>Book Appointment</h4>
                <p class="mb-0 text-muted">Choose a health concern or specialty, then select a doctor and book your appointment.</p>
            </div>
        </div>
    </div>
</div>

@if (fieldCategories.Any())
{
    <div class="row mb-4">
        <div class="col-12">
            <div class="card p-3">
                <strong>Common concerns</strong>
                <div class="mt-2 d-flex flex-wrap gap-2">
                    @foreach (var item in fieldCategories)
                    {
                        <a asp-action="Create" asp-route-specialization="@item.Key" class="btn btn-sm btn-outline-primary">
                            @item.Key
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrWhiteSpace(selectedField))
{
    <div class="row mb-4">
        <div class="col-12">
            <div class="alert alert-info">
                Showing doctors for: <strong>@selectedField</strong>
            </div>
        </div>
    </div>
}

@if (doctors.Any() && ViewBag.SelectedDoctor == null)
{
    <div class="row gy-3">
        @foreach (var doc in doctors)
        {
            var doctorIdValue = doc.TryGetValue("id", out var idValue) ? idValue?.ToString() : string.Empty;
            <div class="col-md-6">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">@doc["fullName"]</h5>
                        <p class="mb-1">Fee: @string.Format("{0:C}", doc["consultationFee"])</p>
                        <p class="mb-2 text-muted">
                            Specializations:
                            @{
                                if (doc["specializations"] is JsonElement specs)
                                {
                                    var items = specs.EnumerateArray().Select(x => x.GetString() ?? string.Empty);
                                    @string.Join(", ", items)
                                }
                            }
                        </p>
                        <a asp-action="Create" asp-route-doctorId="@doctorIdValue" class="btn btn-primary btn-sm">Select this doctor</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
else if (!string.IsNullOrWhiteSpace(selectedField) && !doctors.Any())
{
    <div class="alert alert-warning">
        No doctors were found for that specialty yet. Try another concern or browse doctors directly.
    </div>
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-body p-4">
                <h5 class="mb-4"><i class="bi bi-clock-history text-primary me-2"></i>Appointment Details</h5>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }

                <form method="post">
                    <div class="mb-3">
                        <label class="form-label">Appointment Date & Time</label>
                        <input type="datetime-local" name="appointmentDate" class="form-control" required />
                    </div>

                    @if (ViewBag.SelectedDoctor != null)
                    {
                        var doc = (Dictionary<string, object>)ViewBag.SelectedDoctor;
                        <div class="mb-4 p-3 border rounded bg-light">
                            <h6 class="mb-2">Selected Doctor</h6>
                            <p class="mb-1"><strong>@doc["fullName"]</strong></p>
                            <p class="mb-1">Fee: @string.Format("{0:C}", doc["consultationFee"])</p>
                            <p class="mb-0 text-muted">
                                Specializations:
                                @{
                                    if (doc["specializations"] is JsonElement specs)
                                    {
                                        var items = specs.EnumerateArray().Select(x => x.GetString() ?? string.Empty);
                                        @string.Join(", ", items)
                                    }
                                }
                            </p>
                        </div>
                        <input type="hidden" name="doctorId" value="@ViewBag.DoctorId" />

                        <div class="mb-3">
                            <label class="form-label">Notes</label>
                            <textarea name="notes" class="form-control" rows="3" placeholder="Describe your concern or symptoms..."></textarea>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-lg me-1"></i> Book Appointment
                            </button>
                            <a asp-controller="Doctors" asp-action="Index" class="btn btn-outline-secondary">Browse All Doctors</a>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-secondary">
                            Please choose a concern or doctor to proceed with booking.
                        </div>
                    }
                </form>
            </div>
        </div>
    </div>
</div>