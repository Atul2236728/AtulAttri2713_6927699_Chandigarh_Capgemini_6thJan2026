@using System.Text.Json
@{
    ViewData["Title"] = "Doctors";
}

<div class="card">
    <div class="card-body">
        <h5 class="mb-4"><i class="bi bi-person-badge text-primary me-2"></i>Browse Doctors</h5>

        @if (ViewBag.SpecialtyCategories != null && ((List<KeyValuePair<string, string>>)ViewBag.SpecialtyCategories).Count > 0)
        {
            <div class="mb-4">
                <div class="mb-2 text-muted">Browse by medical concern:</div>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var category in (List<KeyValuePair<string, string>>)ViewBag.SpecialtyCategories)
                    {
                        <a asp-action="Index" asp-route-specialization="@category.Key" class="btn btn-sm btn-outline-primary @(string.Equals(ViewBag.ActiveSpecialization as string, category.Key, StringComparison.OrdinalIgnoreCase) ? "active" : "")">@category.Key</a>
                    }
                </div>
            </div>
        }

        @if (ViewBag.Specializations != null && ((List<string>)ViewBag.Specializations).Count > 0)
        {
            <div class="mb-4">
                <span class="me-2">Filter by specialty:</span>
                <a asp-action="Index" class="btn btn-sm btn-outline-primary @(string.IsNullOrEmpty(ViewBag.ActiveSpecialization) ? "active" : "")">All</a>
                @foreach (var specialty in (List<string>)ViewBag.Specializations)
                {
                    <a asp-action="Index" asp-route-specialization="@specialty" class="btn btn-sm btn-outline-primary @(string.Equals(ViewBag.ActiveSpecialization as string, specialty, StringComparison.OrdinalIgnoreCase) ? "active" : "")">@specialty</a>
                }
            </div>
        }

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-warning">
                @ViewBag.Error
            </div>
        }

            @if (!string.IsNullOrEmpty(ViewBag.ActiveSpecialization))
            {
                <div class="alert alert-light border mt-2">
                    Showing doctors for: <strong>@ViewBag.ActiveSpecialization</strong>
                </div>
            }
        }

        @if (ViewBag.Doctors != null && ViewBag.Doctors.Count > 0)
        {
            <div class="row g-3">
                @foreach (var doc in ViewBag.Doctors)
                {
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body">
                                <div class="d-flex align-items-center mb-2">
                                    <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center me-3"
                                         style="width:45px;height:45px;font-size:1.2rem">
                                        <i class="bi bi-person-fill"></i>
                                    </div>
                                    <div>
                                        <h6 class="mb-0">@doc["fullName"]</h6>
                                        <small class="text-muted">@doc["phoneNumber"]</small>
                                    </div>
                                </div>

                                <div class="mb-2">
                                    <span class="badge bg-success">Fee: @string.Format("{0:C}", doc["consultationFee"])</span>
                                </div>

                                <div>
                                    <strong>Specializations:</strong>
                                    <p class="mb-0 text-muted">
                                        @{
                                            if (doc["specializations"] is JsonElement specs)
                                            {
                                                var items = specs.EnumerateArray().Select(x => x.GetString() ?? string.Empty);
                                                @string.Join(", ", items)
                                            }
                                            else
                                            {
                                                @string.Empty
                                            }
                                        }
                                    </p>
                                </div>

                                <div class="mt-3 d-grid gap-2">
                                    @{ var doctorIdValue = doc["id"] is JsonElement idElement ? idElement.GetInt32() : Convert.ToInt32(doc["id"] ?? 0); }
                                    <a asp-action="Details" asp-route-id="@doctorIdValue" class="btn btn-sm btn-outline-secondary">View Details</a>
                                    <a asp-controller="Appointments" asp-action="Create" asp-route-doctorId="@doctorIdValue" class="btn btn-sm btn-primary">Book Appointment</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-person-badge" style="font-size:3rem"></i>
                <p class="mt-2">No doctors found.</p>
            </div>
        }
    </div>
</div>