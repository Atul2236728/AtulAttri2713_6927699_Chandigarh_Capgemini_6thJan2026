<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HealthCareSmart</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        body { background-color: #f4f6f9; }
        .sidebar {
            min-height: 100vh;
            background: linear-gradient(180deg, #0d6efd, #0a58ca);
            width: 240px;
            position: fixed;
            top: 0; left: 0;
            padding-top: 20px;
            z-index: 100;
        }
        .sidebar a {
            color: rgba(255,255,255,0.85);
            display: block;
            padding: 12px 20px;
            text-decoration: none;
            font-size: 15px;
            border-left: 4px solid transparent;
        }
        .sidebar a:hover, .sidebar a.active {
            background: rgba(255,255,255,0.15);
            color: white;
            border-left: 4px solid white;
        }
        .sidebar a i { margin-right: 10px; }
        .role-option {
            display: block;
            color: rgba(255,255,255,0.9);
            padding: 10px 18px;
            margin-bottom: 8px;
            border-radius: 8px;
            background: rgba(255,255,255,0.05);
            text-decoration: none;
        }
        .role-option.active,
        .role-option:hover {
            background: rgba(255,255,255,0.18);
            color: white;
        }
        .sidebar-brand {
            color: white;
            font-size: 20px;
            font-weight: bold;
            padding: 10px 20px 30px;
            border-bottom: 1px solid rgba(255,255,255,0.2);
            margin-bottom: 10px;
        }
        .main-content {
            margin-left: 240px;
            padding: 30px;
        }
        .topbar {
            background: white;
            padding: 15px 25px;
            border-radius: 10px;
            margin-bottom: 25px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.08);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .card { border: none; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.07); }
        .stat-card { padding: 20px; border-radius: 12px; color: white; }
    </style>
</head>
<body>

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var isLoginPage = string.Equals(currentController, "Account", StringComparison.OrdinalIgnoreCase) &&
                      string.Equals(currentAction, "Login", StringComparison.OrdinalIgnoreCase);
}

<!-- Sidebar -->
<div class="sidebar">
    <div class="sidebar-brand">
        <i class="bi bi-heart-pulse-fill"></i> HealthCareSmart
    </div>
    @if (isLoginPage)
    {
        <div class="px-3">
            <p class="text-white mb-2">Login as</p>
            <a href="javascript:void(0)" class="role-option active" data-role="Patient"><i class="bi bi-person-fill"></i> Patient</a>
            <a href="javascript:void(0)" class="role-option" data-role="Doctor"><i class="bi bi-person-badge-fill"></i> Doctor</a>
            <a href="javascript:void(0)" class="role-option" data-role="Admin"><i class="bi bi-shield-lock-fill"></i> Admin</a>
        </div>
        <div style="position:absolute; bottom:20px; width:100%; padding: 0 20px;">
            <a asp-controller="Account" asp-action="Register">
                <i class="bi bi-pencil-square"></i> Register as Patient
            </a>
        </div>
    }
    else
    {
        <a asp-controller="Dashboard" asp-action="Index">
            <i class="bi bi-speedometer2"></i> Dashboard
        </a>
        <a asp-controller="Appointments" asp-action="Index">
            <i class="bi bi-calendar-check"></i> Appointments
        </a>
        <a asp-controller="Doctors" asp-action="Index">
            <i class="bi bi-person-badge"></i> Doctors
        </a>
        @if ((Context.Session.GetString("UserRole") ?? "").Equals("Patient", StringComparison.OrdinalIgnoreCase))
        {
            <a asp-controller="Billings" asp-action="Index">
                <i class="bi bi-receipt-cutoff"></i> Billing
            </a>
        }
        <a asp-controller="Patients" asp-action="Index">
            <i class="bi bi-people"></i> Patients
        </a>
        <div style="position:absolute; bottom:20px; width:100%;">
            <a asp-controller="Account" asp-action="Logout">
                <i class="bi bi-box-arrow-left"></i> Logout
            </a>
        </div>
    }
</div>

<!-- Main Content -->
<div class="main-content">
    <div class="topbar">
        <h5 class="mb-0">@ViewData["Title"]</h5>
        <span class="text-muted"><i class="bi bi-person-circle me-1"></i> Logged in</span>
    </div>
    @RenderBody()
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
@RenderSection("Scripts", required: false)
</body>
</html>