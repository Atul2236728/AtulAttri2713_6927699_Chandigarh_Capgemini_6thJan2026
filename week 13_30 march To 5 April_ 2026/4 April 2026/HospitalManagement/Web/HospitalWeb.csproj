<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>HospitalWeb</RootNamespace>
    <AssemblyName>HospitalWeb</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <!-- Cookie auth is built into ASP.NET Core SDK - no separate package needed for net8+ -->
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
  </ItemGroup>

</Project>
