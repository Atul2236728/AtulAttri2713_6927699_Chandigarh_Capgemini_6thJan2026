@model HospitalWeb.Models.DoctorDto
@{
    ViewBag.Title = "My Profile";
}

<h4 class="fw-bold mb-4" style="color:#1e3a5f"><i class="fas fa-id-card me-2"></i>My Profile</h4>

@if (Model == null)
{
    <div class="alert alert-warning">Profile not found.</div>
}
else
{
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card text-center p-4">
                <div class="doctor-avatar mx-auto mb-3" style="width:100px;height:100px;font-size:2.5rem;background:linear-gradient(135deg,#1e3a5f,#0077b6);border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff">
                    <i class="fas fa-user-md"></i>
                </div>
                <h4 class="fw-bold">@Model.FullName</h4>
                <p class="text-muted">@Model.Specialization</p>
                <span class="badge @(Model.IsAvailable ? "bg-success" : "bg-secondary") px-3 py-2">
                    @(Model.IsAvailable ? "Available" : "Not Available")
                </span>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card">
                <div class="card-header"><i class="fas fa-info-circle me-2"></i>Professional Details</div>
                <div class="card-body">
                    <div class="row g-3">
                        @foreach (var info in new[] {
                            new{label="Department", value=Model.DepartmentName, icon="fa-hospital"},
                            new{label="Specialization", value=Model.Specialization, icon="fa-stethoscope"},
                            new{label="Qualification", value=Model.Qualification ?? "-", icon="fa-graduation-cap"},
                            new{label="Experience", value=Model.ExperienceYears + " years", icon="fa-briefcase"},
                            new{label="Availability", value=Model.Availability ?? "-", icon="fa-clock"},
                            new{label="Email", value=Model.Email, icon="fa-envelope"},
                            new{label="Phone", value=Model.Phone ?? "-", icon="fa-phone"}
                        })
                        {
                            <div class="col-md-6">
                                <div class="d-flex align-items-center gap-3 p-3 bg-light rounded-3">
                                    <div class="stat-icon blue" style="width:40px;height:40px;font-size:1rem;border-radius:10px">
                                        <i class="fas @info.icon"></i>
                                    </div>
                                    <div>
                                        <div class="text-muted small">@info.label</div>
                                        <div class="fw-semibold">@info.value</div>
                                    </div>
                                </div>
                            </div>
                        }
                        <div class="col-md-6">
                            <div class="d-flex align-items-center gap-3 p-3 bg-light rounded-3">
                                <div class="stat-icon green" style="width:40px;height:40px;font-size:1rem;border-radius:10px">
                                    <i class="fas fa-rupee-sign"></i>
                                </div>
                                <div>
                                    <div class="text-muted small">Consultation Fee</div>
                                    <div class="fw-semibold text-success fs-5">₹@Model.ConsultationFee.ToString("N0")</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
