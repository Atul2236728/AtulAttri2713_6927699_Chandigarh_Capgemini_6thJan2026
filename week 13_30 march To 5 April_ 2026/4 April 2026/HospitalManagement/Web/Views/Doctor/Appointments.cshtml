@* Appointments.cshtml *@
@model List<HospitalWeb.Models.AppointmentDto>
@{
    ViewBag.Title = "My Appointments";
    var statusFilter = ViewBag.StatusFilter as string;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0" style="color:#1e3a5f"><i class="fas fa-calendar-check me-2"></i>All Appointments</h4>
</div>

<!-- Status Filter Tabs -->
<div class="d-flex gap-2 mb-4 flex-wrap">
    @foreach (var s in new[] { ("", "All"), ("Booked", "Booked"), ("Confirmed", "Confirmed"), ("Completed", "Completed"), ("Cancelled", "Cancelled") })
    {
        <a asp-action="Appointments" asp-route-status="@s.Item1"
           class="btn btn-sm @(statusFilter == s.Item1 || (s.Item1 == "" && statusFilter == null) ? "btn-primary" : "btn-outline-secondary")">
            @s.Item2
        </a>
    }
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table data-table mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Patient</th>
                        <th>Date & Time</th>
                        <th>Reason</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in Model)
                    {
                        <tr>
                            <td class="text-muted small">@a.AppointmentId</td>
                            <td>
                                <div class="fw-semibold">@a.PatientName</div>
                                <div class="text-muted small">@a.PatientEmail</div>
                                <div class="text-muted small">@a.PatientPhone</div>
                            </td>
                            <td>
                                <div>@a.AppointmentDate.ToString("dd MMM yyyy")</div>
                                <div class="text-muted small">@a.TimeSlot</div>
                            </td>
                            <td><small class="text-muted">@(a.Reason ?? "-")</small></td>
                            <td>
                                <span class="status-badge status-@a.Status.ToLower()">@a.Status</span>
                                @if (a.HasPrescription) { <span class="badge bg-purple ms-1" style="background:#8e44ad">Rx</span> }
                                @if (a.HasBill) { <span class="badge bg-info ms-1">Bill</span> }
                            </td>
                            <td>
                                <div class="d-flex gap-1 flex-wrap">
                                    @if (a.Status == "Booked")
                                    {
                                        <form asp-action="UpdateStatus" method="post" class="d-inline">
                                            <input type="hidden" name="appointmentId" value="@a.AppointmentId" />
                                            <input type="hidden" name="status" value="Confirmed" />
                                            <button type="submit" class="btn btn-sm btn-outline-success" title="Confirm">
                                                <i class="fas fa-check"></i>
                                            </button>
                                        </form>
                                    }
                                    @if (a.Status != "Completed" && a.Status != "Cancelled")
                                    {
                                        <a asp-action="WritePrescription" asp-route-appointmentId="@a.AppointmentId"
                                           class="btn btn-sm btn-primary" title="Write Prescription">
                                            <i class="fas fa-prescription-bottle-alt"></i>
                                        </a>
                                        <form asp-action="UpdateStatus" method="post" class="d-inline">
                                            <input type="hidden" name="appointmentId" value="@a.AppointmentId" />
                                            <input type="hidden" name="status" value="Cancelled" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger btn-confirm"
                                                    data-confirm="Cancel this appointment?" title="Cancel">
                                                <i class="fas fa-times"></i>
                                            </button>
                                        </form>
                                    }
                                    @if (a.HasPrescription)
                                    {
                                        <a asp-action="ViewPrescription" asp-route-appointmentId="@a.AppointmentId"
                                           class="btn btn-sm btn-outline-info" title="View Prescription">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
