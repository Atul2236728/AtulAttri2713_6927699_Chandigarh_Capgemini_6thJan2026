@model HospitalWeb.Models.CreatePrescriptionViewModel
@{
    ViewBag.Title = "Write Prescription";
    var medicinesJson = Newtonsoft.Json.JsonConvert.SerializeObject(Model.AllMedicines);
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Appointments" class="btn btn-outline-secondary btn-sm me-3"><i class="fas fa-arrow-left"></i></a>
    <h4 class="fw-bold mb-0" style="color:#1e3a5f"><i class="fas fa-prescription-bottle-alt me-2"></i>Write Prescription</h4>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header" style="background:linear-gradient(135deg,#1e3a5f,#0077b6);color:#fff;border-radius:16px 16px 0 0">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="rx-symbol d-inline me-2" style="font-size:1.5rem;font-weight:800;font-style:italic;color:#ffd60a">℞</div>
                        <span class="fw-bold">Patient: @Model.PatientName</span>
                    </div>
                    <span class="small opacity-75">Appointment #@Model.AppointmentId</span>
                </div>
            </div>
            <div class="card-body">
                <form asp-action="WritePrescription" method="post">
                    <input type="hidden" asp-for="AppointmentId" />
                    <input type="hidden" asp-for="PatientName" />

                    <div class="mb-4">
                        <label class="form-label fw-bold"><i class="fas fa-diagnoses me-2 text-primary"></i>Diagnosis *</label>
                        <textarea asp-for="Diagnosis" class="form-control" rows="2"
                                  placeholder="Enter diagnosis / findings..." required></textarea>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold"><i class="fas fa-notes-medical me-2 text-primary"></i>Additional Notes / Instructions</label>
                        <textarea asp-for="Notes" class="form-control" rows="2"
                                  placeholder="Dietary restrictions, lifestyle advice, warnings..."></textarea>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold"><i class="fas fa-calendar-plus me-2 text-primary"></i>Follow-Up Date</label>
                        <input asp-for="FollowUpDate" type="date" class="form-control" />
                    </div>

                    <!-- Medicine Section -->
                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <label class="form-label fw-bold mb-0"><i class="fas fa-pills me-2 text-primary"></i>Prescribed Medicines</label>
                            <button type="button" class="btn btn-sm btn-outline-primary"
                                    onclick="addMedicineRow(@Html.Raw(medicinesJson))">
                                <i class="fas fa-plus me-1"></i>Add Medicine
                            </button>
                        </div>
                        <div id="medicine-rows"></div>
                        <div class="text-end mt-2">
                            <strong>Medicine Total: <span id="med-total" class="text-success">₹0.00</span></strong>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold"><i class="fas fa-align-left me-2 text-primary"></i>Free-text Medicines (optional)</label>
                        <textarea asp-for="Medicines" class="form-control" rows="2"
                                  placeholder="Any medicines not in the list..."></textarea>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-success px-4">
                            <i class="fas fa-save me-2"></i>Save Prescription & Generate Bill
                        </button>
                        <a asp-action="Appointments" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Info Panel -->
    <div class="col-lg-4">
        <div class="card mb-3">
            <div class="card-header"><i class="fas fa-info-circle me-2"></i>Prescription Tips</div>
            <div class="card-body">
                <ul class="list-unstyled small text-muted">
                    <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Add all prescribed medicines using the button above</li>
                    <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Set correct dosage (e.g. 1-0-1 = morning-noon-night)</li>
                    <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Specify duration in days/weeks</li>
                    <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Saving will automatically generate the patient bill</li>
                    <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Appointment will be marked as Completed</li>
                </ul>
            </div>
        </div>
        <div class="card">
            <div class="card-header"><i class="fas fa-rupee-sign me-2"></i>Bill Preview</div>
            <div class="card-body">
                <div class="d-flex justify-content-between py-2 border-bottom">
                    <span class="text-muted">Consultation Fee</span>
                    <span class="fw-bold text-primary">Auto from doctor profile</span>
                </div>
                <div class="d-flex justify-content-between py-2 border-bottom">
                    <span class="text-muted">Medicine Charges</span>
                    <span id="bill-med-preview" class="fw-bold text-success">₹0.00</span>
                </div>
                <div class="text-muted small mt-2"><i class="fas fa-info-circle me-1"></i>Final bill generated after saving.</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
// Keep bill preview in sync with medicine total
const observer = new MutationObserver(function() {
    document.getElementById('bill-med-preview').textContent = document.getElementById('med-total').textContent;
});
observer.observe(document.getElementById('med-total'), { childList: true });
</script>
}
