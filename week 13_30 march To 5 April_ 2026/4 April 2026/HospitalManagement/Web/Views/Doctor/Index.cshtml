@model HospitalWeb.Models.DoctorDashboardDto
@{
    ViewBag.Title = "Doctor Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0" style="color:#1e3a5f"><i class="fas fa-stethoscope me-2"></i>Doctor Dashboard</h4>
        <small class="text-muted">Welcome, Dr. @User.Identity?.Name</small>
    </div>
    <a asp-action="Appointments" class="btn btn-primary"><i class="fas fa-calendar-check me-2"></i>All Appointments</a>
</div>

<!-- Stats -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon orange"><i class="fas fa-calendar-day"></i></div>
            <div>
                <div class="stat-value">@Model.TodayAppointments</div>
                <div class="stat-label">Today's Schedule</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon blue"><i class="fas fa-hourglass-half"></i></div>
            <div>
                <div class="stat-value">@Model.PendingAppointments</div>
                <div class="stat-label">Pending</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon green"><i class="fas fa-check-double"></i></div>
            <div>
                <div class="stat-value">@Model.CompletedToday</div>
                <div class="stat-label">Completed Today</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon purple"><i class="fas fa-procedures"></i></div>
            <div>
                <div class="stat-value">@Model.TotalPatients</div>
                <div class="stat-label">Total Patients</div>
            </div>
        </div>
    </div>
</div>

<!-- Today's Schedule -->
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="fas fa-calendar-day me-2"></i>Today's Schedule</span>
        <span class="badge bg-primary">@DateTime.Today.ToString("dddd, dd MMM yyyy")</span>
    </div>
    <div class="card-body">
        @if (!Model.TodaySchedule.Any())
        {
            <div class="text-center py-5">
                <i class="fas fa-calendar-times fa-3x text-muted mb-3"></i>
                <h5 class="text-muted">No appointments today</h5>
                <p class="text-muted small">Your schedule is clear for today.</p>
            </div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var a in Model.TodaySchedule)
                {
                    <div class="col-lg-6">
                        <div class="border rounded-3 p-3 @(a.Status == "Completed" ? "opacity-75 bg-light" : "bg-white")" style="border-color:@(a.Status=="Booked"?"#007bff":a.Status=="Confirmed"?"#28a745":"#6c757d") !important;border-left-width:4px !important">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <div class="fw-bold">@a.PatientName</div>
                                    <div class="text-muted small"><i class="fas fa-phone me-1"></i>@a.PatientPhone</div>
                                    <div class="text-muted small mt-1"><i class="fas fa-clock me-1"></i>@a.TimeSlot</div>
                                    @if (!string.IsNullOrEmpty(a.Reason))
                                    {
                                        <div class="text-muted small mt-1"><i class="fas fa-comment-medical me-1"></i>@a.Reason</div>
                                    }
                                </div>
                                <span class="status-badge status-@a.Status.ToLower()">@a.Status</span>
                            </div>
                            @if (a.Status != "Completed" && a.Status != "Cancelled")
                            {
                                <div class="d-flex gap-2 mt-3">
                                    <a asp-action="WritePrescription" asp-route-appointmentId="@a.AppointmentId"
                                       class="btn btn-sm btn-primary flex-fill">
                                        <i class="fas fa-prescription me-1"></i>Write Rx
                                    </a>
                                    <form asp-action="UpdateStatus" method="post" class="d-inline">
                                        <input type="hidden" name="appointmentId" value="@a.AppointmentId" />
                                        <input type="hidden" name="status" value="Confirmed" />
                                        <button type="submit" class="btn btn-sm btn-outline-success">
                                            <i class="fas fa-check"></i>
                                        </button>
                                    </form>
                                </div>
                            }
                            else if (a.Status == "Completed" && a.HasPrescription)
                            {
                                <a asp-action="ViewPrescription" asp-route-appointmentId="@a.AppointmentId"
                                   class="btn btn-sm btn-outline-primary mt-2 w-100">
                                    <i class="fas fa-eye me-1"></i>View Prescription
                                </a>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
