@model HospitalWeb.Models.RegisterViewModel
@{
    ViewBag.Title = "Register";
    Layout = "_Layout";
}

<div class="min-vh-100 d-flex align-items-center justify-content-center" style="background:linear-gradient(135deg,#1e3a5f,#0077b6)">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="card border-0 shadow-lg p-4" style="border-radius:20px">
                    <div class="text-center mb-4">
                        <div class="stat-icon blue mx-auto mb-3" style="width:64px;height:64px;font-size:1.5rem">
                            <i class="fas fa-user-plus"></i>
                        </div>
                        <h4 class="fw-bold" style="color:#1e3a5f">Create Account</h4>
                        <p class="text-muted small">Join MediCare as a patient</p>
                    </div>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger py-2">
                            <i class="fas fa-exclamation-circle me-2"></i>
                            @Html.ValidationSummary(true)
                        </div>
                    }

                    <form asp-action="Register" asp-controller="Auth" method="post">
                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label">Full Name</label>
                            <input asp-for="FullName" class="form-control" placeholder="e.g. Rahul Verma" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">Email Address</label>
                            <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Phone" class="form-label">Phone Number</label>
                            <input asp-for="Phone" class="form-control" placeholder="9876543210" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="Password" class="form-label">Password</label>
                            <input asp-for="Password" type="password" class="form-control" placeholder="Min 6 characters" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        <div class="mb-4">
                            <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Repeat password" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 py-2 fw-bold" style="border-radius:12px">
                            <i class="fas fa-user-plus me-2"></i>Register
                        </button>
                    </form>
                    <p class="text-center small mt-3">
                        Already have an account? <a asp-controller="Auth" asp-action="Login" class="text-primary fw-bold">Login</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
