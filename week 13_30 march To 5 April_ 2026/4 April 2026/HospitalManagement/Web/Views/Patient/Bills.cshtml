@model List<HospitalWeb.Models.BillDto>
@{
    ViewBag.Title = "My Bills";
}

<h4 class="fw-bold mb-4" style="color:#1e3a5f"><i class="fas fa-receipt me-2"></i>My Bills</h4>

@if (!Model.Any())
{
    <div class="card p-5 text-center">
        <i class="fas fa-file-invoice-dollar fa-3x text-muted mb-3"></i>
        <h5 class="text-muted">No bills yet</h5>
    </div>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-icon teal"><i class="fas fa-rupee-sign"></i></div>
                <div>
                    <div class="stat-value">₹@Model.Sum(b => b.TotalAmount).ToString("N0")</div>
                    <div class="stat-label">Total Billed</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-icon green"><i class="fas fa-check-circle"></i></div>
                <div>
                    <div class="stat-value">₹@Model.Where(b=>b.PaymentStatus=="Paid").Sum(b=>b.TotalAmount).ToString("N0")</div>
                    <div class="stat-label">Total Paid</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-icon orange"><i class="fas fa-clock"></i></div>
                <div>
                    <div class="stat-value">₹@Model.Where(b=>b.PaymentStatus=="Unpaid").Sum(b=>b.TotalAmount).ToString("N0")</div>
                    <div class="stat-label">Pending</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        @foreach (var b in Model)
        {
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <div class="fw-bold">@b.DoctorName</div>
                                <div class="text-muted small">@b.AppointmentDate.ToString("dd MMM yyyy")</div>
                            </div>
                            <span class="status-badge status-@b.PaymentStatus.ToLower()">@b.PaymentStatus</span>
                        </div>
                        <div class="border-top border-bottom py-2 mb-2">
                            <div class="d-flex justify-content-between text-muted small">
                                <span>Consultation Fee</span><span>₹@b.ConsultationFee.ToString("N0")</span>
                            </div>
                            <div class="d-flex justify-content-between text-muted small">
                                <span>Medicine Charges</span><span>₹@b.MedicineCharges.ToString("N0")</span>
                            </div>
                            @if (b.OtherCharges > 0)
                            {
                                <div class="d-flex justify-content-between text-muted small">
                                    <span>Other</span><span>₹@b.OtherCharges.ToString("N0")</span>
                                </div>
                            }
                            @if (b.Discount > 0)
                            {
                                <div class="d-flex justify-content-between text-success small">
                                    <span>Discount</span><span>-₹@b.Discount.ToString("N0")</span>
                                </div>
                            }
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-bold fs-5 text-primary">₹@b.TotalAmount.ToString("N0")</span>
                            <a asp-action="BillDetail" asp-route-appointmentId="@b.AppointmentId"
                               class="btn btn-sm btn-outline-primary">
                                <i class="fas fa-eye me-1"></i>View Bill
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
