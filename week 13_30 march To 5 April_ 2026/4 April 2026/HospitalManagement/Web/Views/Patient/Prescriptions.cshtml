@model List<HospitalWeb.Models.PrescriptionDto>
@{
    ViewBag.Title = "My Prescriptions";
}

<h4 class="fw-bold mb-4" style="color:#1e3a5f"><i class="fas fa-prescription-bottle-alt me-2"></i>My Prescriptions</h4>

@if (!Model.Any())
{
    <div class="card p-5 text-center">
        <i class="fas fa-prescription-bottle fa-3x text-muted mb-3"></i>
        <h5 class="text-muted">No prescriptions yet</h5>
        <p class="text-muted">Prescriptions appear here after a doctor consultation.</p>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var p in Model)
        {
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header" style="background:linear-gradient(135deg,#1e3a5f,#0077b6);color:#fff;border-radius:16px 16px 0 0">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="fw-bold">@p.DoctorName</div>
                                <small class="opacity-75">@p.AppointmentDate.ToString("dd MMM yyyy")</small>
                            </div>
                            <div style="font-size:1.5rem;font-weight:800;font-style:italic;color:#ffd60a">℞</div>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <div class="text-muted small text-uppercase">Diagnosis</div>
                            <div class="fw-semibold">@p.Diagnosis</div>
                        </div>
                        @if (p.PrescriptionMedicines.Any())
                        {
                            <div class="mb-3">
                                <div class="text-muted small text-uppercase mb-2">Medicines (@p.PrescriptionMedicines.Count)</div>
                                @foreach (var m in p.PrescriptionMedicines.Take(3))
                                {
                                    <div class="d-flex justify-content-between align-items-center py-1 border-bottom">
                                        <div>
                                            <div class="small fw-semibold">@m.MedicineName</div>
                                            <div class="text-muted" style="font-size:.75rem">@m.Dosage · @m.Duration</div>
                                        </div>
                                        <div class="text-success small fw-bold">₹@m.TotalPrice.ToString("N0")</div>
                                    </div>
                                }
                                @if (p.PrescriptionMedicines.Count > 3)
                                {
                                    <div class="text-muted small mt-1">+@(p.PrescriptionMedicines.Count - 3) more...</div>
                                }
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(p.FollowUpDate))
                        {
                            <div class="d-flex align-items-center gap-2 p-2 bg-info bg-opacity-10 rounded-2">
                                <i class="fas fa-calendar-check text-info"></i>
                                <small>Follow-up: <strong>@p.FollowUpDate</strong></small>
                            </div>
                        }
                    </div>
                    <div class="card-footer bg-transparent">
                        <a asp-action="PrescriptionDetail" asp-route-id="@p.PrescriptionId"
                           class="btn btn-outline-primary btn-sm w-100">
                            <i class="fas fa-eye me-2"></i>View Full Prescription
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
