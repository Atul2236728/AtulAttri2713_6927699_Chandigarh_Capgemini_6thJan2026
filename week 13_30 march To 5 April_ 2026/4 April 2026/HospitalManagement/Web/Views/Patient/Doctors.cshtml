@* Doctors.cshtml *@
@model List<HospitalWeb.Models.DoctorDto>
@{
    ViewBag.Title = "Find Doctors";
    var departments = ViewBag.Departments as List<HospitalWeb.Models.DepartmentDto> ?? new();
    var selectedDept = ViewBag.SelectedDept as int?;
    var search = ViewBag.Search as string;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0" style="color:#1e3a5f"><i class="fas fa-user-md me-2"></i>Find a Doctor</h4>
    <span class="text-muted">@Model.Count doctor@(Model.Count != 1 ? "s" : "") found</span>
</div>

<!-- Search & Filter -->
<div class="card mb-4">
    <div class="card-body">
        <form asp-action="Doctors" method="get">
            <div class="row g-3">
                <div class="col-md-5">
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                        <input type="text" name="search" class="form-control" placeholder="Search by name or specialization..." value="@search" />
                    </div>
                </div>
                <div class="col-md-5">
                    <select name="departmentId" class="form-select">
                        <option value="">All Departments</option>
                        @foreach (var d in departments)
                        {
                            <option value="@d.DepartmentId" selected="@(selectedDept == d.DepartmentId)">@d.DepartmentName</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100"><i class="fas fa-filter me-1"></i>Filter</button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Department Pills -->
<div class="d-flex gap-2 flex-wrap mb-4">
    <a asp-action="Doctors" class="btn btn-sm @(selectedDept == null ? "btn-primary" : "btn-outline-secondary")">All</a>
    @foreach (var d in departments)
    {
        <a asp-action="Doctors" asp-route-departmentId="@d.DepartmentId"
           class="btn btn-sm @(selectedDept == d.DepartmentId ? "btn-primary" : "btn-outline-secondary")">
            @d.DepartmentName
        </a>
    }
</div>

<div class="row g-4">
    @foreach (var doc in Model)
    {
        <div class="col-lg-4 col-md-6">
            <div class="doctor-card">
                <div class="doctor-card-header">
                    <div class="doctor-avatar"><i class="fas fa-user-md"></i></div>
                    <div class="doctor-name">@doc.FullName</div>
                    <div class="doctor-dept"><i class="fas fa-hospital-alt me-1"></i>@doc.DepartmentName</div>
                </div>
                <div class="doctor-card-body">
                    <div class="doctor-info-item"><i class="fas fa-stethoscope"></i>@doc.Specialization</div>
                    <div class="doctor-info-item"><i class="fas fa-graduation-cap"></i>@doc.Qualification</div>
                    <div class="doctor-info-item"><i class="fas fa-briefcase-medical"></i>@doc.ExperienceYears years experience</div>
                    <div class="doctor-info-item"><i class="fas fa-clock"></i>@doc.Availability</div>
                </div>
                <div class="doctor-card-footer">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="doctor-fee">₹@doc.ConsultationFee.ToString("N0")<small class="text-muted">/visit</small></span>
                        <span class="badge @(doc.IsAvailable ? "bg-success" : "bg-secondary")">
                            @(doc.IsAvailable ? "Available" : "Unavailable")
                        </span>
                    </div>
                    @if (doc.IsAvailable)
                    {
                        <a asp-action="BookAppointment" asp-route-doctorId="@doc.DoctorId" class="btn btn-primary w-100">
                            <i class="fas fa-calendar-plus me-2"></i>Book Appointment
                        </a>
                    }
                    else
                    {
                        <button class="btn btn-secondary w-100" disabled>Not Available</button>
                    }
                </div>
            </div>
        </div>
    }
    @if (!Model.Any())
    {
        <div class="col-12">
            <div class="card p-5 text-center">
                <i class="fas fa-search fa-3x text-muted mb-3"></i>
                <h5 class="text-muted">No doctors found</h5>
                <p class="text-muted">Try adjusting your search or filter criteria</p>
            </div>
        </div>
    }
</div>
