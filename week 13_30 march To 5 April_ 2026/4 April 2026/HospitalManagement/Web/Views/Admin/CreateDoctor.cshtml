@model HospitalWeb.Models.CreateDoctorViewModel
@{
    ViewBag.Title = "Add Doctor";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Doctors" class="btn btn-outline-secondary btn-sm me-3"><i class="fas fa-arrow-left"></i></a>
    <h4 class="fw-bold mb-0" style="color:#1e3a5f"><i class="fas fa-user-md me-2"></i>Add New Doctor</h4>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="CreateDoctor" method="post">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Full Name *</label>
                    <input asp-for="FullName" class="form-control" placeholder="Dr. Full Name" />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Email *</label>
                    <input asp-for="Email" class="form-control" placeholder="doctor@hospital.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Password *</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Min 6 chars" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Phone</label>
                    <input asp-for="Phone" class="form-control" placeholder="9876543210" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Department *</label>
                    <select asp-for="DepartmentId" class="form-select">
                        <option value="">-- Select Department --</option>
                        @foreach (var d in Model.Departments)
                        {
                            <option value="@d.DepartmentId">@d.DepartmentName</option>
                        }
                    </select>
                    <span asp-validation-for="DepartmentId" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Specialization *</label>
                    <input asp-for="Specialization" class="form-control" placeholder="e.g. Cardiologist" />
                    <span asp-validation-for="Specialization" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Experience (Years)</label>
                    <input asp-for="ExperienceYears" type="number" class="form-control" min="0" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Consultation Fee (₹) *</label>
                    <input asp-for="ConsultationFee" type="number" class="form-control" step="0.01" />
                    <span asp-validation-for="ConsultationFee" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Availability</label>
                    <input asp-for="Availability" class="form-control" placeholder="e.g. Mon-Fri 9AM-5PM" />
                </div>
                <div class="col-12">
                    <label class="form-label">Qualification</label>
                    <input asp-for="Qualification" class="form-control" placeholder="e.g. MBBS, MD (Cardiology)" />
                </div>
                <div class="col-12 mt-2">
                    <button type="submit" class="btn btn-primary px-5">
                        <i class="fas fa-save me-2"></i>Create Doctor
                    </button>
                    <a asp-action="Doctors" class="btn btn-outline-secondary ms-2">Cancel</a>
                </div>
            </div>
        </form>
    </div>
</div>
