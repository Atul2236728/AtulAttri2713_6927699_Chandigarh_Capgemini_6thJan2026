@model List<HospitalWeb.Models.MedicineDto>
@{
    ViewBag.Title = "Medicines";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0" style="color:#1e3a5f"><i class="fas fa-pills me-2"></i>Medicine Catalogue</h4>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addMedModal">
        <i class="fas fa-plus me-2"></i>Add Medicine
    </button>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table data-table mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Medicine Name</th>
                        <th>Unit Price</th>
                        <th>Unit</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in Model)
                    {
                        <tr>
                            <td class="text-muted small">@m.MedicineId</td>
                            <td><div class="fw-semibold"><i class="fas fa-capsules me-2 text-info"></i>@m.MedicineName</div></td>
                            <td class="fw-bold text-success">₹@m.UnitPrice.ToString("N2")</td>
                            <td><span class="badge bg-light text-dark">per @m.Unit</span></td>
                            <td><span class="badge @(m.IsActive ? "bg-success" : "bg-secondary")">@(m.IsActive ? "Active" : "Inactive")</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Add Medicine Modal -->
<div class="modal fade" id="addMedModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" style="border-radius:16px">
            <div class="modal-header" style="background:#1e3a5f;color:#fff;border-radius:16px 16px 0 0">
                <h5 class="modal-title"><i class="fas fa-pills me-2"></i>Add Medicine</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form asp-action="CreateMedicine" method="post">
                    <div class="mb-3">
                        <label class="form-label">Medicine Name *</label>
                        <input name="medicineName" class="form-control" placeholder="e.g. Paracetamol 500mg" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Unit Price (₹) *</label>
                        <input name="unitPrice" type="number" step="0.01" class="form-control" placeholder="e.g. 5.00" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Unit</label>
                        <select name="unit" class="form-select">
                            <option>Tablet</option>
                            <option>Capsule</option>
                            <option>Syrup</option>
                            <option>Injection</option>
                            <option>Piece</option>
                            <option>ml</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary w-100"><i class="fas fa-save me-2"></i>Add Medicine</button>
                </form>
            </div>
        </div>
    </div>
</div>
