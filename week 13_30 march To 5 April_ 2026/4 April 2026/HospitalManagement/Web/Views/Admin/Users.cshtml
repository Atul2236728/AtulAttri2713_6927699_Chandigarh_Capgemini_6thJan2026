@model List<HospitalWeb.Models.UserDto>
@{
    ViewBag.Title = "User Management";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0" style="color:#1e3a5f"><i class="fas fa-users me-2"></i>User Management</h4>
    <div class="d-flex gap-2">
        <span class="badge bg-danger p-2">Admin: @Model.Count(u=>u.Role=="Admin")</span>
        <span class="badge bg-info p-2">Doctors: @Model.Count(u=>u.Role=="Doctor")</span>
        <span class="badge bg-success p-2">Patients: @Model.Count(u=>u.Role=="Patient")</span>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table data-table mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Role</th>
                        <th>Joined</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        <tr>
                            <td class="text-muted small">@u.UserId</td>
                            <td class="fw-semibold">@u.FullName</td>
                            <td>@u.Email</td>
                            <td>@(u.Phone ?? "-")</td>
                            <td>
                                <span class="badge @(u.Role=="Admin"?"bg-danger":u.Role=="Doctor"?"bg-info":"bg-success")">@u.Role</span>
                            </td>
                            <td>@u.CreatedAt.ToString("dd MMM yyyy")</td>
                            <td>
                                <span class="badge @(u.IsActive?"bg-success":"bg-secondary")">@(u.IsActive?"Active":"Inactive")</span>
                            </td>
                            <td>
                                @if (u.Role != "Admin")
                                {
                                    <form asp-action="ToggleUser" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@u.UserId" />
                                        <button type="submit" class="btn btn-sm @(u.IsActive?"btn-outline-warning":"btn-outline-success")"
                                                title="@(u.IsActive?"Deactivate":"Activate")">
                                            <i class="fas @(u.IsActive?"fa-user-slash":"fa-user-check")"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
