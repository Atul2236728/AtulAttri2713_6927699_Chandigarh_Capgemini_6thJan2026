@* Patients.cshtml *@
@model List<HospitalWeb.Models.PatientProfileDto>
@{
    ViewBag.Title = "Patients";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0" style="color:#1e3a5f"><i class="fas fa-procedures me-2"></i>Patient Records</h4>
    <span class="badge bg-primary p-2">Total: @Model.Count</span>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table data-table mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Patient</th>
                        <th>Contact</th>
                        <th>Gender</th>
                        <th>Blood Group</th>
                        <th>DOB</th>
                        <th>Address</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td class="text-muted small">@p.UserId</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="stat-icon blue" style="width:36px;height:36px;font-size:.9rem;border-radius:50%">
                                        <i class="fas fa-user"></i>
                                    </div>
                                    <div>
                                        <div class="fw-semibold">@p.FullName</div>
                                        <div class="text-muted small">@p.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td>@p.Phone</td>
                            <td>@(p.Gender ?? "-")</td>
                            <td>
                                @if (!string.IsNullOrEmpty(p.BloodGroup))
                                {
                                    <span class="badge bg-danger">@p.BloodGroup</span>
                                }
                                else { <span class="text-muted">-</span> }
                            </td>
                            <td>@(p.DateOfBirth ?? "-")</td>
                            <td><small class="text-muted">@(p.Address ?? "-")</small></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
