@page

<style>
* { box-sizing: border-box; margin: 0; padding: 0; }

body {
    min-height: 100vh;
    background: #0a0f1e;
    font-family: 'DM Sans', sans-serif;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
}

.reg-bg {
    position: fixed;
    inset: 0;
    background: radial-gradient(ellipse 80% 60% at 80% 20%, rgba(16,185,129,0.15) 0%, transparent 60%),
                radial-gradient(ellipse 60% 50% at 20% 80%, rgba(99,102,241,0.12) 0%, transparent 60%);
    z-index: 0;
}

.reg-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    width: 900px;
    max-width: 95vw;
    min-height: 560px;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 40px 100px rgba(0,0,0,0.6);
}

.reg-form-panel {
    background: #111827;
    padding: 48px 44px;
    display: flex;
    flex-direction: column;
    justify-content: center;
}

.form-panel-title {
    font-size: 26px;
    font-weight: 700;
    color: #f9fafb;
    margin-bottom: 6px;
}
.form-panel-sub {
    color: #6b7280;
    font-size: 14px;
    margin-bottom: 28px;
}

.eb-field {
    margin-bottom: 16px;
}
.eb-label {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: #9ca3af;
    margin-bottom: 7px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}
.eb-input, .eb-select {
    width: 100%;
    background: #1f2937;
    border: 1.5px solid #374151;
    border-radius: 10px;
    padding: 12px 16px;
    color: #f9fafb;
    font-size: 15px;
    font-family: 'DM Sans', sans-serif;
    transition: border-color 0.2s, box-shadow 0.2s;
    outline: none;
    appearance: none;
}
.eb-input:focus, .eb-select:focus {
    border-color: #10b981;
    box-shadow: 0 0 0 3px rgba(16,185,129,0.15);
}
.eb-input::placeholder { color: #4b5563; }
.eb-select option { background: #1f2937; }

.eb-btn-primary {
    width: 100%;
    padding: 13px;
    background: linear-gradient(135deg, #059669, #10b981);
    border: none;
    border-radius: 10px;
    color: #fff;
    font-size: 15px;
    font-weight: 600;
    font-family: 'DM Sans', sans-serif;
    cursor: pointer;
    margin-top: 8px;
    transition: transform 0.15s, box-shadow 0.15s;
}
.eb-btn-primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(16,185,129,0.4);
}

.eb-divider {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 16px 0;
    color: #374151;
    font-size: 13px;
}
.eb-divider::before, .eb-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: #1f2937;
}

.eb-btn-ghost {
    width: 100%;
    padding: 12px;
    background: transparent;
    border: 1.5px solid #374151;
    border-radius: 10px;
    color: #9ca3af;
    font-size: 14px;
    font-weight: 500;
    font-family: 'DM Sans', sans-serif;
    cursor: pointer;
    transition: all 0.2s;
}
.eb-btn-ghost:hover { border-color: #10b981; color: #6ee7b7; }

/* Hero side */
.reg-hero {
    background: linear-gradient(145deg, #064e3b 0%, #065f46 50%, #0f3d2e 100%);
    padding: 56px 48px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    overflow: hidden;
}
.reg-hero::before {
    content: '';
    position: absolute;
    width: 300px; height: 300px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.06);
    bottom: -80px; right: -80px;
}
.reg-hero::after {
    content: '';
    position: absolute;
    width: 200px; height: 200px;
    border-radius: 50%;
    background: rgba(16,185,129,0.15);
    top: 40px; right: -40px;
    filter: blur(40px);
}
.hero-brand {
    display: flex; align-items: center; gap: 12px;
}
.hero-brand-icon {
    width: 44px; height: 44px;
    background: rgba(255,255,255,0.12);
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 22px; color: #6ee7b7;
}
.hero-brand-name {
    font-family: 'Playfair Display', serif;
    color: #fff; font-size: 24px; font-weight: 700;
}
.hero-content h1 {
    color: #fff; font-size: 30px; font-weight: 700;
    line-height: 1.3; margin-bottom: 16px;
}
.hero-content p {
    color: rgba(255,255,255,0.6); font-size: 15px; line-height: 1.7;
}
.hero-features { display: flex; flex-direction: column; gap: 14px; }
.hero-feat {
    display: flex; align-items: center; gap: 12px;
    color: rgba(255,255,255,0.7); font-size: 14px;
}
.hero-feat-icon {
    width: 32px; height: 32px;
    background: rgba(255,255,255,0.08);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 15px; color: #6ee7b7; flex-shrink: 0;
}

@@media (max-width: 700px) {
    .reg-grid { grid-template-columns: 1fr; }
    .reg-hero { display: none; }
}
</style>

<div class="reg-bg"></div>

<div class="reg-grid">
    <!-- Form panel (left) -->
    <div class="reg-form-panel">
        <div class="form-panel-title">Create account</div>
        <div class="form-panel-sub">Get started — it's free and takes a minute</div>

        <div class="eb-field">
            <label class="eb-label">Username</label>
            <input id="username" class="eb-input" placeholder="Choose a username" />
        </div>
        <div class="eb-field">
            <label class="eb-label">Password</label>
            <input id="password" type="password" class="eb-input" placeholder="Create a strong password" />
        </div>
        <div class="eb-field">
            <label class="eb-label">Account type</label>
            <select id="role" class="eb-select">
                <option value="user">User — Browse &amp; Book Events</option>
                <option value="admin">Admin — Manage Platform</option>
            </select>
        </div>

        <button onclick="register()" class="eb-btn-primary">
            Create Account &nbsp;<i class="bi bi-arrow-right"></i>
        </button>

        <div class="eb-divider">already registered?</div>

        <button onclick="goToLogin()" class="eb-btn-ghost">
            <i class="bi bi-box-arrow-in-right"></i> &nbsp;Back to Sign In
        </button>
    </div>

    <!-- Hero panel (right) -->
    <div class="reg-hero">
        <div class="hero-brand">
            <div class="hero-brand-icon"><i class="bi bi-ticket-perforated-fill"></i></div>
            <span class="hero-brand-name">Eventify</span>
        </div>
        <div class="hero-content">
            <h1>Join thousands of<br/>event enthusiasts</h1>
            <p>From concerts to conferences, find and book events that matter to you.</p>
        </div>
        <div class="hero-features">
            <div class="hero-feat">
                <div class="hero-feat-icon"><i class="bi bi-lightning-charge"></i></div>
                Instant booking confirmation
            </div>
            <div class="hero-feat">
                <div class="hero-feat-icon"><i class="bi bi-shield-check"></i></div>
                Secure &amp; encrypted payments
            </div>
            <div class="hero-feat">
                <div class="hero-feat-icon"><i class="bi bi-bell"></i></div>
                Real-time event updates
            </div>
        </div>
    </div>
</div>

<script>
async function register() {
    const username = document.getElementById("username").value;
    const password = document.getElementById("password").value;
    const role = document.getElementById("role").value;

    if (!username || !password) {
        alert("Please fill all fields ❌");
        return;
    }

    const res = await fetch("http://localhost:5003/api/auth/register", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ username, password, role })
    });

    if (res.ok) {
        alert("Registration Successful ✅");
        window.location.href = "/Login";
    } else {
        const err = await res.text();
        alert("Registration Failed ❌: " + err);
    }
}

function goToLogin() {
    window.location.href = "/Login";
}
</script>
