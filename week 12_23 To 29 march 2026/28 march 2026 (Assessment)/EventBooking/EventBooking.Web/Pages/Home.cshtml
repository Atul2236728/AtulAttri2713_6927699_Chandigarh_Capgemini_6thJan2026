}
.bookings-table td {
    padding: 14px 18px;
    font-size: 14px;
    color: #374151;
    border-bottom: 1px solid #f1f5f9;
}
.bookings-table tr:last-child td { border-bottom: none; }
.bookings-table tr:hover td { background: #f8fafc; }
.status-badge {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
