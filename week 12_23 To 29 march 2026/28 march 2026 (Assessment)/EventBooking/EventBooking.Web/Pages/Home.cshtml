.btn-add-event i { font-size: 15px; }

/* MODAL */
.modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.55);
    backdrop-filter: blur(4px);
    z-index: 999;
    align-items: center;
    justify-content: center;
}
.modal-overlay.open {
    display: flex;
    animation: fadeOverlay 0.2s ease;
}
@@keyframes fadeOverlay {
    from { opacity: 0; }
    to   { opacity: 1; }
}

.modal-box {
    background: #fff;
    border-radius: 20px;
    width: 500px;
    max-width: 95vw;
    box-shadow: 0 30px 80px rgba(0,0,0,0.25);
    animation: slideUp 0.25s ease;
    overflow: hidden;
}
@@keyframes slideUp {
    from { opacity: 0; transform: translateY(30px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
}

.modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 22px 28px 0;
}
.modal-title {
    font-size: 18px;
    font-weight: 700;
    color: #0f172a;
    display: flex;
    align-items: center;
    gap: 10px;
}
.modal-title i { color: #6366f1; font-size: 20px; }
.modal-close {
    width: 32px; height: 32px;
    border: none;
    background: #f1f5f9;
    border-radius: 8px;
    color: #64748b;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    font-size: 14px;
    transition: all 0.15s;
}
.modal-close:hover { background: #fee2e2; color: #dc2626; }

.modal-body { padding: 20px 28px; }

.modal-field { margin-bottom: 16px; }
.modal-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
}
.modal-label {
    display: block;
    font-size: 12px;
    font-weight: 700;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 7px;
}
.modal-input {
    width: 100%;
    background: #f8fafc;
    border: 1.5px solid #e2e8f0;
    border-radius: 10px;
    padding: 11px 14px;
    color: #0f172a;
    font-size: 14px;
    font-family: 'DM Sans', sans-serif;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
}
.modal-input:focus {
    border-color: #6366f1;
    box-shadow: 0 0 0 3px rgba(99,102,241,0.12);
    background: #fff;
}
.modal-textarea {
    resize: vertical;
    min-height: 80px;
    line-height: 1.5;
}

.modal-error {
    background: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 8px;
    padding: 10px 14px;
    color: #dc2626;
    font-size: 13px;
    margin-top: 4px;
}

.modal-footer {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 10px;
    padding: 16px 28px 22px;
    border-top: 1px solid #f1f5f9;
}
.modal-btn-cancel {
    padding: 9px 20px;
    background: transparent;
    border: 1.5px solid #e2e8f0;
    border-radius: 9px;
    color: #64748b;
    font-size: 14px;
    font-weight: 600;
    font-family: 'DM Sans', sans-serif;
    cursor: pointer;
    transition: all 0.15s;
}
.modal-btn-cancel:hover { border-color: #94a3b8; color: #374151; }

.modal-btn-submit {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 9px 22px;
    background: linear-gradient(135deg, #4f46e5, #6366f1);
    border: none;
    border-radius: 9px;
    color: #fff;
    font-size: 14px;
    font-weight: 600;
    font-family: 'DM Sans', sans-serif;
    cursor: pointer;
    transition: all 0.18s;
}
.modal-btn-submit:hover {
    box-shadow: 0 4px 14px rgba(79,70,229,0.4);
    transform: translateY(-1px);
}
.modal-btn-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
}

/* EMPTY STATE */
.empty-state {
    text-align: center;
    padding: 48px 24px;
    color: #94a3b8;
}
.empty-state i { font-size: 40px; display: block; margin-bottom: 12px; }
.empty-state p { font-size: 14px; }
</style>

<div class="dash-root">

    <!-- SIDEBAR -->
    <aside class="dash-sidebar">
        <div class="sidebar-section-label">Menu</div>
        <button class="sidebar-link active" onclick="showSection('events')">
            <i class="bi bi-calendar-event-fill"></i> Events
        </button>
        <button class="sidebar-link" onclick="showSection('bookings')">
            <i class="bi bi-ticket-detailed-fill"></i> My Bookings
        </button>
        <div id="adminMenuItems" style="display:none; width:100%;">
            <div class="sidebar-divider"></div>
            <div class="sidebar-section-label">Admin</div>
            <button class="sidebar-link" onclick="showSection('users'); loadUsers();">
                <i class="bi bi-people-fill"></i> Users
            </button>
        </div>
    </aside>

    <!-- MAIN -->
    <div class="dash-content">

        <!-- Welcome header -->
        <div class="page-header">
            <div>
                <div class="page-title" id="sectionTitle">Upcoming Events</div>
                <div class="page-sub" id="sectionSub">Discover and book events near you</div>
            </div>
        </div>

        <!-- Stats -->
        <div class="stat-row" id="statsRow">
            <div class="stat-card">
                <div class="stat-icon purple"><i class="bi bi-calendar2-event-fill"></i></div>
                <div>
                    <div class="stat-label">Total Events</div>
                    <div class="stat-value" id="statEvents">—</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon blue"><i class="bi bi-ticket-detailed-fill"></i></div>
                <div>
                    <div class="stat-label">My Bookings</div>
                    <div class="stat-value" id="statBookings">—</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon green"><i class="bi bi-person-check-fill"></i></div>
                <div>
                    <div class="stat-label">Account</div>
                    <div class="stat-value" id="statRole">—</div>
                </div>
            </div>
        </div>

        <!-- EVENTS SECTION -->
        <div id="eventsSection">
            <div class="section-hdr">
                <div class="section-title"><i class="bi bi-stars"></i> Available Events <span class="section-count" id="eventsCount">0</span></div>
                <button id="addEventBtn" onclick="openAddEventModal()" class="btn-add-event" style="display:none;">
