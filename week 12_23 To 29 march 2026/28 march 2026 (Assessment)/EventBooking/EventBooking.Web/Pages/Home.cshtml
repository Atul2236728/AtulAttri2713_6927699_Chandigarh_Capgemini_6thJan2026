                    <div class="modal-field">
                        <label class="modal-label">Event Title</label>
                        <input id="newTitle" class="modal-input" placeholder="e.g. Music Concert 2026" />
                    </div>
                    <div class="modal-field">
                        <label class="modal-label">Description</label>
                        <textarea id="newDescription" class="modal-input modal-textarea" placeholder="Brief description of the event..."></textarea>
