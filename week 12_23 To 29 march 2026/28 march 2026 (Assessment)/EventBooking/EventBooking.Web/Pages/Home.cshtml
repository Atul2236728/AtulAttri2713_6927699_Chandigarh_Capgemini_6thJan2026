                <div class="empty-state"><i class="bi bi-hourglass-split"></i><p>Loading events...</p></div>
            </div>
        </div>

        <!-- ADD EVENT MODAL -->
        <div id="addEventOverlay" class="modal-overlay" onclick="closeAddEventModal(event)">
            <div class="modal-box">
                <div class="modal-header">
                    <div class="modal-title"><i class="bi bi-calendar-plus-fill"></i> Create New Event</div>
                    <button class="modal-close" onclick="closeAddEventModal()"><i class="bi bi-x-lg"></i></button>
                </div>
