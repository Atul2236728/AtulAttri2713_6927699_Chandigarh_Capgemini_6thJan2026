@page
@model IndexModel

<script>
if (!localStorage.getItem("token")) {
    window.location.href = "/Login";
}
function getToken() { return localStorage.getItem("token"); }
function getRole() { return localStorage.getItem("role"); }
function getUsername() { return localStorage.getItem("username"); }
</script>

<style>
/* === DASHBOARD LAYOUT === */
.dash-root {
    display: flex;
    min-height: calc(100vh - 70px);
    background: #f1f5f9;
}

/* SIDEBAR */
.dash-sidebar {
    width: 260px;
    flex-shrink: 0;
    background: #0f172a;
    min-height: calc(100vh - 70px);
    position: sticky;
    top: 70px;
    height: calc(100vh - 70px);
    display: flex;
    flex-direction: column;
    padding: 28px 16px;
    gap: 4px;
}

.sidebar-section-label {
    font-size: 11px;
    font-weight: 600;
    color: #475569;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    padding: 0 12px;
    margin: 12px 0 6px;
}

.sidebar-link {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    border-radius: 10px;
    border: none;
    background: transparent;
    color: #94a3b8;
    font-size: 14px;
    font-weight: 500;
    font-family: 'DM Sans', sans-serif;
