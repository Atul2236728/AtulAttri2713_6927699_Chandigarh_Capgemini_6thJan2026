    gap: 7px;
    padding: 9px 20px;
    background: linear-gradient(135deg, #4f46e5, #6366f1);
    border: none;
    border-radius: 10px;
    color: #fff;
    font-size: 14px;
    font-weight: 600;
    font-family: 'DM Sans', sans-serif;
    cursor: pointer;
    transition: all 0.18s;
