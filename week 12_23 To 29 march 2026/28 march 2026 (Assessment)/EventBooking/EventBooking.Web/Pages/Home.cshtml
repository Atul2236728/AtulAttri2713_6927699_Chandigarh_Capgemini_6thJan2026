<script>
// Init
document.getElementById("statRole").innerText = getRole() === "admin" ? "Admin" : "Member";

if (getRole() === "admin") {
    document.getElementById("adminMenuItems").style.display = "block";
}

function showSection(name) {
    document.getElementById("eventsSection").style.display = name === "events" ? "block" : "none";
    document.getElementById("bookingsSection").style.display = name === "bookings" ? "block" : "none";
    document.getElementById("usersSection").style.display = name === "users" ? "block" : "none";
    document.getElementById("statsRow").style.display = name === "events" ? "grid" : "none";

    const titles = {
        events: ["Upcoming Events", "Discover and book events near you"],
        bookings: ["My Bookings", "View your confirmed reservations"],
        users: ["User Management", "All registered platform users"]
    };
    document.getElementById("sectionTitle").innerText = titles[name][0];
    document.getElementById("sectionSub").innerText = titles[name][1];

    document.querySelectorAll(".sidebar-link").forEach(btn => btn.classList.remove("active"));
    event.currentTarget.classList.add("active");

    if (name === "bookings") loadBookings();
}

/* EVENTS */
function loadEvents() {
    fetch("http://localhost:5003/api/events")
        .then(r => r.json())
        .then(data => {
            document.getElementById("statEvents").innerText = data.length;
            document.getElementById("eventsCount").innerText = data.length;
            if (!data.length) {
                eventsList.innerHTML = '<div class="empty-state"><i class="bi bi-calendar-x"></i><p>No events available right now.</p></div>';
                return;
            }
            let html = "";
            data.forEach(e => {
                const dateStr = new Date(e.date).toLocaleDateString("en-US", { weekday: "short", month: "short", day: "numeric" });
                html += `
                <div class="event-card">
                    <div class="event-card-banner"></div>
                    <div class="event-card-body">
                        <span class="event-category">Event</span>
                        <div class="event-name">${e.title}</div>
                        <div class="event-detail"><i class="bi bi-geo-alt-fill"></i> ${e.location}</div>
                        <div class="event-detail"><i class="bi bi-calendar3"></i> ${dateStr}</div>
                    </div>
                    <div class="event-card-footer">
                        <div class="seats-badge"><i class="bi bi-chair"></i> ${e.availableSeats} seats left</div>
                        <button onclick="book(${e.id})" class="btn-book">Book Now</button>
                    </div>
                </div>`;
            });
            document.getElementById("eventsList").innerHTML = html;
        });
}

/* BOOK */
function book(id) {
    let seats = prompt("How many seats would you like to book?");
    if (!seats || isNaN(seats) || parseInt(seats) < 1) return;
    fetch("http://localhost:5003/api/bookings", {
        method: "POST",
        headers: {
            "Content-Type": "application/json",
            "Authorization": "Bearer " + getToken()
        },
        body: JSON.stringify({ eventId: id, userId: getUsername(), seatsBooked: parseInt(seats) })
    }).then(() => { loadEvents(); loadBookings(); });
}

/* BOOKINGS */
function loadBookings() {
    // Fetch both bookings and events in parallel so we can always show event names
    Promise.all([
        fetch("http://localhost:5003/api/bookings", {
            headers: { "Authorization": "Bearer " + getToken() }
        }).then(r => r.json()),
        fetch("http://localhost:5003/api/events").then(r => r.json()).catch(() => [])
    ]).then(([bookings, events]) => {
        document.getElementById("statBookings").innerText = bookings.length;

        // Build a quick lookup map: eventId -> event title
        const eventMap = {};
        events.forEach(e => {
            eventMap[e.id]   = e.title;
            eventMap[e.Id]   = e.title || e.Title;
        });

        if (!bookings.length) {
            document.getElementById("bookingList").innerHTML = '<tr><td colspan="4"><div class="empty-state"><i class="bi bi-ticket-x"></i><p>No bookings yet. Go book an event!</p></div></td></tr>';
            return;
        }

        let html = "";
        bookings.forEach(b => {
            // Try every possible field name the API might return
            const eid = b.eventId || b.EventId || b.event_id;
            const eventName = b.eventTitle || b.EventTitle
                           || b.event?.title || b.Event?.Title
                           || b.eventName   || b.EventName
                           || b.title       || b.Title
                           || (eid && eventMap[eid])
                           || null;

            const displayName = eventName
                ? `<strong>${eventName}</strong>`
                : `<span style="color:#94a3b8;font-style:italic;">Event #${eid || '?'}</span>`;

            html += `<tr>
                <td>${displayName}</td>
                <td>${b.userId || b.UserId || b.username || b.Username || "—"}</td>
                <td>${b.seatsBooked || b.SeatsBooked || "—"}</td>
                <td><span class="status-badge">Confirmed</span></td>
            </tr>`;
        });
        document.getElementById("bookingList").innerHTML = html;
    });
}

/* USERS (admin) */
async function loadUsers() {
    const res = await fetch("http://localhost:5003/api/auth/users", {
        headers: { "Authorization": "Bearer " + getToken() }
    });
    const users = await res.json();
    if (!users.length) {
        document.getElementById("usersList").innerHTML = '<div class="empty-state"><i class="bi bi-person-x"></i><p>No users found.</p></div>';
        return;
    }
    let html = "";
    users.forEach(u => {
        const initial = u.username ? u.username[0].toUpperCase() : "?";
        html += `<div class="user-row">
            <div class="user-avatar">${initial}</div>
            <div class="user-name">${u.username}</div>
            <span class="user-role-badge ${u.role}">${u.role}</span>
        </div>`;
    });
    document.getElementById("usersList").innerHTML = html;
}

/* SHOW ADD EVENT BUTTON FOR ADMIN */
if (getRole() === "admin") {
    document.getElementById("addEventBtn").style.display = "flex";
}

/* ADD EVENT MODAL */
function openAddEventModal() {
    document.getElementById("newTitle").value = "";
    document.getElementById("newDescription").value = "";
    document.getElementById("newLocation").value = "";
    document.getElementById("newDate").value = "";
    document.getElementById("newSeats").value = "";
    document.getElementById("modalError").style.display = "none";
    document.getElementById("addEventOverlay").classList.add("open");
}

function closeAddEventModal(e) {
    if (!e || e.target === document.getElementById("addEventOverlay")) {
        document.getElementById("addEventOverlay").classList.remove("open");
    }
}

async function submitAddEvent() {
    const title       = document.getElementById("newTitle").value.trim();
    const description = document.getElementById("newDescription").value.trim();
    const location    = document.getElementById("newLocation").value.trim();
    const date        = document.getElementById("newDate").value;
    const seats       = parseInt(document.getElementById("newSeats").value);
    const errEl       = document.getElementById("modalError");
    const submitBtn   = document.querySelector(".modal-btn-submit");

    if (!title || !description || !location || !date || !seats || seats < 1) {
        errEl.innerText = "Please fill in all fields correctly.";
        errEl.style.display = "block";
        return;
    }

    errEl.style.display = "none";
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<i class="bi bi-hourglass-split"></i> Creating...';

    try {
        const res = await fetch("http://localhost:5003/api/events", {
            method: "POST",
            headers: {
                "Content-Type": "application/json",
                "Authorization": "Bearer " + getToken()
            },
            body: JSON.stringify({ title, description, location, date: new Date(date).toISOString(), availableSeats: seats })
        });

        if (res.ok) {
            document.getElementById("addEventOverlay").classList.remove("open");
            loadEvents();
        } else {
            const msg = await res.text();
            errEl.innerText = "Failed to create event: " + msg;
            errEl.style.display = "block";
        }
    } catch (err) {
        errEl.innerText = "Network error. Please try again.";
        errEl.style.display = "block";
    }

    submitBtn.disabled = false;
    submitBtn.innerHTML = '<i class="bi bi-check-lg"></i> Create Event';
}

/* INIT */
loadEvents();
setTimeout(loadBookings, 300);
</script>
