@model List<EmployeePortal.Models.Employee>

<h2>Employee List</h2>

<table class="table table-striped">
    <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Department</th>
    </tr>

    @foreach (var e in Model)
    {
        <tr>
            <td>@e.Name</td>
            <td>@e.Email</td>
            <td>@e.Department</td>
        </tr>
    }
</table>