@model StudentManagementSystem.Models.Student

<div class="container mt-5">

    <div class="row">

        <div class="col-md-6 offset-md-3">

            <div class="card shadow p-4">

                <h3 class="text-primary text-center mb-4">
                    🎓 Student Registration
                </h3>

                <form asp-action="Register" method="post">

                    <input asp-for="Name" class="form-control mb-2" placeholder="Full Name" />
                    <span asp-validation-for="Name" class="text-danger"></span>

                    <input asp-for="Age" class="form-control mb-2" placeholder="Age" />
                    <span asp-validation-for="Age" class="text-danger"></span>

                    <input asp-for="Email" class="form-control mb-2" placeholder="Email" />
                    <span asp-validation-for="Email" class="text-danger"></span>

                    <button class="btn btn-primary w-100 mt-3">
                        Register Student
                    </button>

                </form>

            </div>

        </div>

    </div>

</div>